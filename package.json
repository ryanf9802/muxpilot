{
  "name": "muxpilot",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "packageManager": "pnpm@10.28.0",
  "scripts": {
    "dev": "node -e \"console.error('Use pnpm app start dev to start or reuse the dev server.'); process.exit(1)\"",
    "app": "node scripts/app.mjs",
    "start:dev": "node scripts/start-dev.mjs",
    "start:prod": "node scripts/start-prod.mjs",
    "stop": "node scripts/stop.mjs all",
    "stop:dev": "node scripts/stop.mjs dev",
    "stop:prod": "node scripts/stop.mjs prod",
    "restart": "node scripts/app.mjs restart all",
    "restart:dev": "node scripts/restart.mjs dev",
    "restart:prod": "node scripts/restart.mjs prod",
    "status": "node scripts/app.mjs status all",
    "logs": "node scripts/app.mjs logs prod",
    "icons:generate": "node scripts/generate-icons.mjs",
    "pwa:setup": "node scripts/setup-pwa-certs.mjs setup",
    "pwa:trust": "node scripts/setup-pwa-certs.mjs trust",
    "pwa:certs:status": "node scripts/setup-pwa-certs.mjs status",
    "db:reset": "node scripts/reset-dbs.mjs",
    "db:reset:dev": "node scripts/reset-dbs.mjs --dev",
    "db:reset:prod": "node scripts/reset-dbs.mjs --prod",
    "dev:server": "pnpm --filter @muxpilot/server dev",
    "dev:web": "pnpm --filter @muxpilot/web dev",
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "test": "pnpm -r test"
  },
  "devDependencies": {
    "@types/node": "^24.0.10",
    "typescript": "^5.8.3"
  }
}
