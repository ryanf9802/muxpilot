# Set to 1/true/yes/on to bind the backend and Web UI for same-LAN phone access.
MUXPILOT_LAN_ENABLED=0

# Optional. Enables prompt-only activity summaries and OpenAI usage/cost tracking.
OPENAI_API_KEY=

# Optional. Encrypts exported .mpsession files. Use the same value on an
# importing host. Plaintext files remain importable when this is configured.
MUXPILOT_SESSION_FILE_KEY=
